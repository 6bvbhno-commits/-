modules = ["nodejs-24", "python-base-3.13"]

[deployment]
run = ["bash", "-c", "source /home/user/.bot-venv/bin/activate && bash bot/run.sh"]
deploymentTarget = "vm"
build = ["sh", "-c", "python3 -m venv /home/user/.bot-venv && /home/user/.bot-venv/bin/pip install -r bot/requirements.txt -q"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot"

[[workflows.workflow]]
name = "Telegram Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash bot/run.sh"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["xcodebuild", "zlib"]

[userenv]

[userenv.shared]
MOCK_MODE = "false"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80
